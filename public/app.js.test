// Minimal test
const { useState } = React;
const { Button, Card, Space } = antd;

function TestApp() {
  const [count, setCount] = useState(0);
  return React.createElement('div', { style: { padding: 50, color: '#fff' } },
    React.createElement('h1', null, 'Hello World! React works.'),
    React.createElement('p', null, 'Count: ' + count),
    React.createElement(Button, { type: 'primary', onClick: () => setCount(count + 1) }, 'Click me')
  );
}

ReactDOM.createRoot(document.getElementById('root')).render(React.createElement(TestApp));
